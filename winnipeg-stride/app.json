{
  "expo": {
    "name": "Winnipeg Stride",
    "slug": "winnipeg-stride",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "winnipeg-stride",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#3D5BA7",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.datathon.winnipegstride"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3D5BA7"
      },
      "package": "com.datathon.winnipegstride"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
